# Khóa Anthropic Claude API (bắt buộc để sinh biên bản)
ANTHROPIC_API_KEY=sk-ant-...

# Model Claude dùng để sửa transcript + sinh biên bản
CLAUDE_MODEL=claude-sonnet-4-6

# ───────── Chép lời (Speech-to-Text) ─────────
# local  = tự host faster-whisper (cần cài faster-whisper + tải model)
# openai = gọi API tương thích OpenAI (Whisper host sẵn — không cần GPU)
STT_PROVIDER=local
# Ngôn ngữ ép cho STT
STT_LANGUAGE=vi

# --- Khi STT_PROVIDER=local: cấu hình faster-whisper ---
WHISPER_MODEL=medium
# device: cpu | cuda  (cuda nếu máy có GPU NVIDIA + CUDA)
WHISPER_DEVICE=cpu
# compute_type: int8 (CPU nhanh, nhẹ) | float16 (GPU) | int8_float16
WHISPER_COMPUTE_TYPE=int8

# --- Khi STT_PROVIDER=openai: API tương thích OpenAI ---
# OpenAI:  OPENAI_BASE_URL=https://api.openai.com/v1   STT_MODEL=whisper-1 (hoặc gpt-4o-transcribe)
# Groq:    OPENAI_BASE_URL=https://api.groq.com/openai/v1   STT_MODEL=whisper-large-v3
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
STT_MODEL=whisper-1

# Thư mục lưu file (mp3 + transcript). Mặc định ./data
DATA_DIR=./data

# CORS: danh sách origin được phép, cách nhau bởi dấu phẩy. * = cho phép tất cả
CORS_ORIGINS=*
